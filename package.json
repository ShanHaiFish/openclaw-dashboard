{
  "name": "@openclaw/dashboard",
  "version": "1.0.0",
  "description": "A stunning, real-time monitoring dashboard for OpenClaw AI agents — featuring WebSocket live updates, ⌘K command palette, multi-theme support, i18n (EN/ZH), and a plugin system.",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules/.cache",
    "publish:dry": "npm pack --dry-run",
    "prepublishOnly": "npm test && npm run build",
    "postpublish": "git push origin main --tags"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.0.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hotkeys-hook": "^4.5.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "server": {
    "port": 3777
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "monitoring",
    "ai-agents",
    "real-time",
    "websocket",
    "react",
    "express",
    "command-palette",
    "i18n",
    "themes",
    "plugin-system"
  ],
  "author": "OpenClaw Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw-dashboard.git"
  },
  "main": "server/index.js",
  "files": [
    "server/",
    "dist/",
    "public/",
    "src/plugins/",
    "src/i18n/",
    "index.html",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "directories": {
    "doc": "docs"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw-dashboard/issues"
  },
  "homepage": "https://github.com/ShanHaiFish/openclaw-dashboard#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
